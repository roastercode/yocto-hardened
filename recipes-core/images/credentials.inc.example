# SPDX-License-Identifier: MIT
#
# credentials.inc.example — template for image credentials
#
# Copy to credentials.inc and set your own password hash.
# DO NOT commit credentials.inc to version control.
#
# Generate a SHA-512 password hash:
#   openssl passwd -6 yourpassword
#
# Example (password: changeme):
#   EXTRA_USERS_PARAMS = "usermod -p '$6$...' root;"

inherit extrausers

# Replace the hash below with the output of: openssl passwd -6 yourpassword
EXTRA_USERS_PARAMS = "usermod -p '\$6\$REPLACEME\$REPLACETHISWITHYOURHASHFROMOPENSSL.' root;"
