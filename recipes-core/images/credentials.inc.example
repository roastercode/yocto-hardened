# SPDX-License-Identifier: MIT
#
# credentials.inc.example — template for image root password
#
# USAGE:
#   cp credentials.inc.example credentials.inc
#
# This file is tracked in git. credentials.inc is excluded (.gitignore).
# Never commit credentials.inc — only this example file.
#
# HOW TO GENERATE YOUR OWN PASSWORD HASH:
#
#   openssl passwd -6 yourpassword
#
#   This outputs a SHA-512 hash in the format: $6$salt$hash
#   Each '$' must be escaped as '\$' in this BitBake file.
#
#   Example workflow:
#     $ openssl passwd -6 mypassword
#     $6$xyz$abc...
#
#     In credentials.inc:
#     EXTRA_USERS_PARAMS = "usermod -p '\$6\$xyz\$abc...' root;"
#
# SECURITY NOTE:
#   The hash below uses the password "root" and is provided as a
#   functional default for lab/QEMU use only. Replace it with your
#   own hash before any deployment beyond a local test environment.
#   For production, use a secrets vault (HashiCorp Vault, SOPS, etc.)
#   to inject the hash at build time without storing it in any file.
#
# The password for the hash below is: root
# Generated with: openssl passwd -6 root
#
inherit extrausers
EXTRA_USERS_PARAMS = "usermod -p '\$6\$90ZDSoGEq0T.Ml8k\$FtMxCZPRpZlDpMNLDhsQT6P2m8TWqXF7x82uulguK.htMt9rFJg2MgjqqE4Oyeg/EU18MixhIYbUnsvBspJ4T.' root;"
