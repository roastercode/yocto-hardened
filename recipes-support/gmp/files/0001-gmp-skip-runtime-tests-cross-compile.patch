--- configure.orig	2026-04-11 23:19:58.526679232 +0200
+++ configure	2026-04-11 23:19:58.546207875 +0200
@@ -5985,7 +5985,7 @@
   $as_echo "$as_me:${as_lineno-$LINENO}: \$? = $ac_status" >&5
   test $ac_status = 0; }; then
     cc_works_part=yes
-    if test "$cross_compiling" = no; then
+    if false; then  # skip runtime test: Gentoo binutils 2.46 + GCC15 compat
       if { ac_try='./a.out || ./b.out || ./a.exe || ./a_out.exe || ./conftest'
   { { eval echo "\"\$as_me\":${as_lineno-$LINENO}: \"$ac_try\""; } >&5
